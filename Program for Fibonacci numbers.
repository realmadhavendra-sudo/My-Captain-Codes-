 # Fibonacci Series Program
# The Fibonacci sequence is:
# 0, 1, 1, 2, 3, 5, 8, 13, ...

# Taking input from user
n = int(input("Enter the number of terms: "))

# First two Fibonacci numbers
a = 0
b = 1

print("Fibonacci Series:")

if n <= 0:
    print("Please enter a positive integer.")
elif n == 1:
    print(a)
else:
    for i in range(n):
        print(a, end=" ")
        c = a + b
        a = b
        b = c
